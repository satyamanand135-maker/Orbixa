{
    "name": "react-example",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "tsx server.ts",
        "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
        "start": "node dist/server.cjs",
        "clean": "rm -rf dist server.js",
        "lint": "tsc --noEmit",
        "test": "cross-env NODE_ENV=test npx tsx -r dotenv/config tests/api.test.ts",
        "test:pipeline": "cross-env NODE_ENV=test npx tsx -r dotenv/config tests/pipeline.test.ts",
        "test:billing": "cross-env NODE_ENV=test npx tsx -r dotenv/config tests/billing.test.ts",
        "test:routes": "cross-env NODE_ENV=test npx tsx -r dotenv/config tests/routes.test.ts",
        "test:all": "npm test && npm run test:pipeline && npm run test:billing && npm run test:routes",
        "db:migrate": "tsx scripts/migrate.ts",
        "db:migrate:pg": "tsx -e \"import('./server-pg.ts').then(m => m.runPgMigrations())\"",
        "db:backup": "tsx scripts/backup.ts",
        "coverage:check": "tsx scripts/coverage-check.ts",
        "ci:test": "npm run test:all && npm run coverage:check",
        "celery:worker": "celery -A celery_worker worker --loglevel=info --concurrency=4"
    },
    "dependencies": {
        "@google/genai": "^2.4.0",
        "@tailwindcss/vite": "^4.1.14",
        "@types/multer": "^2.2.0",
        "@vitejs/plugin-react": "^5.0.4",
        "bcryptjs": "^3.0.3",
        "bull": "^4.10.0",
        "dotenv": "^16.2.3",
        "express": "^4.21.2",
        "express-session": "^1.17.3",
        "json2csv": "^5.0.0",
        "jsonwebtoken": "^8.5.1",
        "lucide-react": "^0.546.0",
        "mongoose": "^8.0.0",
        "motion": "^12.23.24",
        "multer": "^2.2.0",
        "passport": "^0.6.0",
        "passport-github2": "^0.1.12",
        "passport-google-oauth20": "^2.0.0",
        "pdf-parse": "^1.1.1",
        "react": "^19.0.1",
        "react-dom": "^19.0.1",
        "recharts": "^3.9.1",
        "redis": "^4.6.5",
        "vite": "^6.2.3"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/express": "^4.17.21",
        "@types/express-session": "^1.19.0",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^22.14.0",
        "@types/pdf-parse": "^1.1.5",
        "@types/supertest": "^7.2.0",
        "autoprefixer": "^10.4.21",
        "cross-env": "^7.0.3",
        "esbuild": "^0.25.0",
        "supertest": "^7.2.2",
        "tailwindcss": "^4.1.14",
        "tsx": "^4.21.0",
        "typescript": "~5.8.2",
        "vite": "^6.2.3"
    }
}
