# Application
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# Database - MongoDB
# Local default: mongodb://localhost:27017/dhub
# MongoDB Atlas example: mongodb+srv://<username>:<password>@<cluster-url>/dhub
MONGODB_URI=mongodb://localhost:27017/dhub
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=replace_with_mongo_root_password
MONGODB_MAX_POOL_SIZE=50
MONGODB_MIN_POOL_SIZE=5

# Redis
# Local defaults are fine if Redis is running locally.
# Use REDIS_URL only if your Redis provider gives a full connection URL.
REDIS_URL=redis://:replace_with_redis_password@localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=replace_with_redis_password

# Auth/session secrets
# Generate each secret separately:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_with_generated_session_secret_min_32_chars
JWT_SECRET=replace_with_generated_jwt_secret_min_32_chars
JWT_EXPIRY=24h
REFRESH_TOKEN_SECRET=replace_with_generated_refresh_token_secret_min_32_chars

# Encryption key for stored OAuth credentials
# Generate once and keep it safe. Do not change it after storing connector credentials.
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace_with_generated_32_byte_hex_encryption_key

# AI/ML APIs
# Get from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=replace_with_google_ai_studio_gemini_api_key

# OAuth - Google Drive connector
# Get from Google Cloud Console OAuth credentials.
GOOGLE_OAUTH_CLIENT_ID=replace_with_google_oauth_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=replace_with_google_oauth_client_secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/connectors/oauth/google-drive/callback

# OAuth - GitHub connector
# Get from GitHub Developer settings > OAuth Apps.
GITHUB_OAUTH_CLIENT_ID=replace_with_github_oauth_client_id
GITHUB_OAUTH_CLIENT_SECRET=replace_with_github_oauth_client_secret
GITHUB_OAUTH_REDIRECT_URI=http://localhost:3000/api/connectors/oauth/github/callback

# OAuth - Notion connector
# Get from Notion integrations: https://www.notion.so/my-integrations
NOTION_OAUTH_CLIENT_ID=replace_with_notion_oauth_client_id
NOTION_OAUTH_CLIENT_SECRET=replace_with_notion_oauth_client_secret
NOTION_OAUTH_REDIRECT_URI=http://localhost:3000/api/connectors/oauth/notion/callback

# OAuth - Slack connector
# Get from Slack API apps: https://api.slack.com/apps
SLACK_OAUTH_CLIENT_ID=replace_with_slack_oauth_client_id
SLACK_OAUTH_CLIENT_SECRET=replace_with_slack_oauth_client_secret
SLACK_OAUTH_REDIRECT_URI=http://localhost:3000/api/connectors/oauth/slack/callback

# PII Detection
PII_DETECTION_ENABLED=true
PII_REDACTION_ENABLED=true

# PDF Parsing
PDF_PARSING_TIMEOUT=30000
MAX_PDF_SIZE_MB=50

# Vector Database
# Qdrant local default: http://localhost:6333
VECTOR_DB_TYPE=qdrant
VECTOR_DB_URL=http://localhost:6333
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Security
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Feature Flags
ENABLE_BATCH_OPERATIONS=true
ENABLE_CONNECTOR_SYNC=true
ENABLE_ADVANCED_PII=true
ENABLE_VECTOR_SYNC=true

# Optional: Analytics/error tracking
ANALYTICS_ENABLED=false
SENTRY_DSN=replace_with_sentry_dsn_or_leave_empty

# Optional: S3 file storage
AWS_ACCESS_KEY_ID=replace_with_aws_access_key_id_or_leave_empty
AWS_SECRET_ACCESS_KEY=replace_with_aws_secret_access_key_or_leave_empty
AWS_S3_BUCKET=replace_with_s3_bucket_name_or_leave_empty
AWS_REGION=us-east-1
